# Environment variables template
# Copy to .env and fill in values. NEVER commit .env to git.
# All variables listed here are required unless marked [optional].

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production              # production | staging | development
APP_NAME="My AI App"
IMAGE_TAG=latest                # Set by CI to the commit SHA

# ── Container Registry ────────────────────────────────────────────────────────
REGISTRY_URL=ghcr.io/your-org   # e.g., ghcr.io/mycompany

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=changeme            # PostgreSQL password for 'app' user

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=changeme-use-256-bit-random-value

# ── Frontend ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme
PROMETHEUS_URL=http://prometheus:9090   # Used by ops-agent MCP

# ── AI Agent Configuration ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                      # For spec-agent, dev-agent
OPENAI_API_KEY=                         # For review-agent (gpt-5.3-codex)
GITHUB_TOKEN=                           # For MCP github server (fine-grained PAT)

# ── Notifications ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=              # [optional] ops-agent alerts
PAGERDUTY_INTEGRATION_KEY=      # [optional] escalation
